          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Москва, Красная площадь\",\n  \"latitude\": 55.7539,\n  \"longitude\": 37.6208,\n  \"altitude\": 130.0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/locations/",
              "host": ["{{baseUrl}}"],
              "path": ["api", "locations", ""]
            },
            "description": "Создание нового местоположения метеостанции"
          }
        },
        {
          "name": "Get Location by ID",
          "request": {
            "method": "GET",
            "header": [],
